    {
      "name": "Notes",
      "item": [
        {
          "name": "Create Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Note\",\n  \"content\": \"This is the content of my note\",\n  \"status\": \"Active\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/notes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["notes"]
            }
          }
        },
        {
          "name": "Get All Notes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/notes?page=1&page_size=10&search=&status=",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["notes"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "status",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Get Note Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/notes/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["notes", "1"]
            }
          }
        },
        {
          "name": "Update Note",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"content\": \"Updated content\",\n  \"status\": \"Active\",\n  \"active\": true,\n  \"archived\": false\n}"
            },
            "url": {
              "raw": "http://localhost:8080/notes/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["notes", "1"]
            }
          }
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/notes/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["notes", "1"]
            }
          }
        }
      ]
